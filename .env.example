# ============================================================================
# MeControla — .env.example
# Copie este arquivo para .env e preencha os valores.
# Em producao (VPS Hostinger): arquivo .env no raiz do repo, chmod 600, dono root.
# NUNCA comite o arquivo .env com valores reais.
# Valores CHANGE_ME_* sao rejeitados pelo Config.Validate() em ENVIRONMENT=production.
# Referencia: ADR-009 (D-17, D-18, D-21)
# ============================================================================

# ---------------------------------------------------------------------------
# Aplicacao
# ---------------------------------------------------------------------------
ENVIRONMENT=local
APP_MODE=server

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
PORT=8080
SERVICE_NAME_API=mecontrola-api
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=mecontrola
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_NAME=mecontrola_db
DB_SSL_MODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_IDLE_CONNS=5

# Testes de integracao
DATABASE_URL=postgres://mecontrola:CHANGE_ME_USE_STRONG_PASSWORD@localhost:5432/mecontrola_db?sslmode=disable

# ---------------------------------------------------------------------------
# Observabilidade (OpenTelemetry)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Grafana Cloud: Authorization=Basic <base64(instanceId:token)>
OTEL_EXPORTER_OTLP_HEADERS=CHANGE_ME_GENERATE_SECURE_SECRET_KEY_MIN_64_CHARS
OTEL_TRACE_SAMPLE_RATE=1.0
LOG_LEVEL=debug
LOG_FORMAT=json
SERVICE_VERSION=dev

# ---------------------------------------------------------------------------
# Caddy (reverse proxy) — necessario apenas em producao
# ---------------------------------------------------------------------------
APP_DOMAIN=CHANGE_ME_yourdomain.com
CADDY_EMAIL=CHANGE_ME_your@email.com

# ---------------------------------------------------------------------------
# Deploy (usado por deployment/scripts/deploy.sh e GitHub Actions)
# ---------------------------------------------------------------------------
IMAGE_NAME=ghcr.io/limateixeiratecnologia/mecontrola
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Backup offsite (pg-dump.sh) — producao
# ---------------------------------------------------------------------------
# rclone remote configurado com: rclone config
BACKUP_REMOTE=CHANGE_ME_backup:mecontrola-backups
# Gerar chave age: age-keygen -o key.txt  — armazenar fora do servidor
AGE_RECIPIENT=CHANGE_ME_age1...
RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Outbox Transacional (RF-26 / D-03)
# ---------------------------------------------------------------------------
OUTBOX_DISPATCHER_ENABLED=true
OUTBOX_DISPATCHER_TICK_INTERVAL=500ms
OUTBOX_DISPATCHER_BATCH_SIZE=50
OUTBOX_DISPATCHER_HANDLER_TIMEOUT=10s
OUTBOX_RETRY_MAX_ATTEMPTS=15
OUTBOX_RETRY_BASE_BACKOFF=2s
OUTBOX_RETRY_MAX_BACKOFF=5m
OUTBOX_HOUSEKEEPING_RETENTION_DAYS=90
OUTBOX_HOUSEKEEPING_SCHEDULE=@daily
OUTBOX_REAPER_INTERVAL=@every 1m
OUTBOX_REAPER_STUCK_AFTER=5m

# ---------------------------------------------------------------------------
# Promtail / Grafana Cloud Loki — producao (profile observability)
# ---------------------------------------------------------------------------
LOKI_URL=CHANGE_ME_https://logs-prod-xxx.grafana.net/loki/api/v1/push
LOKI_USER_ID=CHANGE_ME_loki_user_id
LOKI_API_KEY=CHANGE_ME_loki_api_key

# ---------------------------------------------------------------------------
# KIWIFY
# ---------------------------------------------------------------------------
KIWIFY_CLIENT_SECRET=CHANGE_ME_generate_secure_secret_key_min_64_chars
KIWIFY_CLIENT_ID=CHANGE_ME_generate_secure_client_id
KIWIFY_ACCOUNT_ID=CHANGE_ME_generate_secure_account_id

# ---------------------------------------------------------------------------
# Onboarding via Magic Token (E3)
# ---------------------------------------------------------------------------
ONBOARDING_TOKEN_TTL_DAYS=7
ONBOARDING_OUTREACH_GAP_HOURS=2
ONBOARDING_OUTREACH_ENABLED=false
ONBOARDING_CHECKOUT_CORS_ORIGINS=https://www.mecontrola.app.br,https://mecontrola.app.br
ONBOARDING_TRUSTED_PROXIES=127.0.0.1/32,::1/128
ONBOARDING_CHECKOUT_RATE_LIMIT_PER_MIN=10
ONBOARDING_CHECKOUT_RATE_LIMIT_BURST=5
ONBOARDING_STATE_RATE_LIMIT_PER_MIN=30
ONBOARDING_STATE_RATE_LIMIT_BURST=10
# Mapa plan_id=URL (um por linha, separado por newline)
ONBOARDING_KIWIFY_CHECKOUT_URLS=
ONBOARDING_KIWIFY_ALLOWED_HOSTS=pay.kiwify.com.br
ONBOARDING_META_RETENTION_DAYS=30
ONBOARDING_META_CLEANUP_SCHEDULE=30 3 * * *
ONBOARDING_TOKEN_EXPIRATION_SCHEDULE=0 3 * * *
ONBOARDING_MAX_TOKEN_LOOKUP_ATTEMPTS=5
ONBOARDING_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_byte_token_encryption_key

# ---------------------------------------------------------------------------
# WhatsApp / Meta Cloud API (E3)
# ---------------------------------------------------------------------------
META_PHONE_NUMBER_ID=CHANGE_ME_meta_phone_number_id
META_ACCESS_TOKEN=CHANGE_ME_meta_access_token
META_APP_SECRET=CHANGE_ME_meta_app_secret
META_APP_SECRET_NEXT=
META_VERIFY_TOKEN=CHANGE_ME_meta_verify_token
META_OUTREACH_TEMPLATE_NAME=activation_reminder
META_BOT_NUMBER_E164=+5511900000000
META_BOT_NUMBER_DISPLAY=+55 11 9XXXX-XXXX
WA_MSG_WELCOME_ACTIVATED=Sua conta foi ativada com sucesso! Bem-vindo ao MeControla.
WA_MSG_ALREADY_ACTIVE=Sua conta ja esta ativa.
WA_MSG_CODE_ALREADY_USED_OTHER_ACCOUNT=Este codigo ja foi utilizado por outra conta.
WA_MSG_PAYMENT_STILL_PROCESSING_RETRY=Seu pagamento ainda esta sendo processado. Tente novamente em alguns minutos.
WA_MSG_CODE_EXPIRED_CONTACT_SUPPORT=Este codigo expirou. Entre em contato com o suporte.
WA_MSG_CODE_INVALID_CHECK_AGAIN=Codigo invalido. Verifique o link de ativacao e tente novamente.
WA_MSG_SYSTEM_UNAVAILABLE_RETRY=Sistema temporariamente indisponivel. Tente novamente em alguns minutos.
WA_MSG_PLEASE_USE_ATIVAR_COMMAND=Para ativar sua conta, envie: ATIVAR seguido do seu codigo de ativacao.
WA_MSG_INVALID_COUNTRY=Numero de telefone nao suportado. Apenas numeros brasileiros sao aceitos.
