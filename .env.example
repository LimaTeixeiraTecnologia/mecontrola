# Contrato de variaveis exigidas pelas tarefas e pela aplicacao.
# Copie para .env (local) e .env.test (testes de integracao).
# Nunca commite os arquivos reais (.env, .env.test).
# Valores CHANGE_ME_* sao rejeitados pelo Config.Validate() em ENVIRONMENT=production.

# Aplicacao
APP_NAME=mecontrola
BIN_DIR=bin

# Ambiente
APP_MODE=server
ENVIRONMENT=local

# HTTP
PORT=8080
SERVICE_NAME_API=mecontrola-api

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_USER=mecontrola
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_MIN_16_CHARS
DB_NAME=mecontrola
DB_SSL_MODE=disable

# Testes de integracao
DATABASE_URL=postgres://mecontrola:CHANGE_ME_USE_STRONG_PASSWORD_MIN_16_CHARS@localhost:5432/mecontrola?sslmode=disable

# Observabilidade (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic CHANGE_ME_GRAFANA_CLOUD_TOKEN
OTEL_TRACE_SAMPLE_RATE=1.0
LOG_LEVEL=debug
LOG_FORMAT=json
SERVICE_VERSION=dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
