# ============================================================================
# MeControla — .env.example
# Copie este arquivo para .env e preencha os valores.
# Em producao (VPS Hostinger): arquivo .env no raiz do repo, chmod 600, dono root.
# NUNCA comite o arquivo .env com valores reais.
# Valores CHANGE_ME_* sao rejeitados pelo Config.Validate() em ENVIRONMENT=production.
# Referencia: ADR-009 (D-17, D-18, D-21)
# ============================================================================

# ---------------------------------------------------------------------------
# Aplicacao
# ---------------------------------------------------------------------------
ENVIRONMENT=local
APP_MODE=server

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
PORT=8080
SERVICE_NAME_API=mecontrola-api
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=mecontrola
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_NAME=mecontrola_db
DB_SSL_MODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_IDLE_CONNS=5

# Testes de integracao
DATABASE_URL=postgres://mecontrola:CHANGE_ME_USE_STRONG_PASSWORD@localhost:5432/mecontrola_db?sslmode=disable

# ---------------------------------------------------------------------------
# Observabilidade (OpenTelemetry)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Grafana Cloud: Authorization=Basic <base64(instanceId:token)>
OTEL_EXPORTER_OTLP_HEADERS=CHANGE_ME_GENERATE_SECURE_SECRET_KEY_MIN_64_CHARS
OTEL_TRACE_SAMPLE_RATE=1.0
LOG_LEVEL=debug
LOG_FORMAT=json
SERVICE_VERSION=dev

# ---------------------------------------------------------------------------
# Caddy (reverse proxy) — necessario apenas em producao
# ---------------------------------------------------------------------------
APP_DOMAIN=CHANGE_ME_yourdomain.com
CADDY_EMAIL=CHANGE_ME_your@email.com

# ---------------------------------------------------------------------------
# Deploy (usado por deployment/scripts/deploy.sh e GitHub Actions)
# ---------------------------------------------------------------------------
IMAGE_NAME=ghcr.io/limateixeiratecnologia/mecontrola
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Backup offsite (pg-dump.sh) — producao
# ---------------------------------------------------------------------------
# rclone remote configurado com: rclone config
BACKUP_REMOTE=CHANGE_ME_backup:mecontrola-backups
# Gerar chave age: age-keygen -o key.txt  — armazenar fora do servidor
AGE_RECIPIENT=CHANGE_ME_age1...
RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Promtail / Grafana Cloud Loki — producao (profile observability)
# ---------------------------------------------------------------------------
LOKI_URL=CHANGE_ME_https://logs-prod-xxx.grafana.net/loki/api/v1/push
LOKI_USER_ID=CHANGE_ME_loki_user_id
LOKI_API_KEY=CHANGE_ME_loki_api_key
