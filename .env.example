# ============================================================================
# MeControla — .env.example
# Copie este arquivo para .env e preencha os valores.
# Em producao (VPS Hostinger): arquivo .env no raiz do repo, chmod 600, dono root.
# NUNCA comite o arquivo .env com valores reais.
# Valores CHANGE_ME_* sao rejeitados pelo Config.Validate() em ENVIRONMENT=production.
# Referencia: ADR-009 (D-17, D-18, D-21)
# ============================================================================

# ---------------------------------------------------------------------------
# Aplicacao
# ---------------------------------------------------------------------------
ENVIRONMENT=local
APP_MODE=server

# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
PORT=8080
SERVICE_NAME_API=mecontrola-api
SERVICE_NAME_WORKER=mecontrola-worker
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Em production: lista explicita obrigatoria; wildcard (*) ou vazio causam erro de boot.
# Exemplo production: CORS_ALLOWED_ORIGINS=https://app.mecontrola.com.br,https://checkout.mecontrola.com.br
AUTH_RATE_LIMIT_PER_USER_PER_MIN=120
AUTH_RATE_LIMIT_PER_USER_BURST=60

# ---------------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=mecontrola
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_NAME=mecontrola_db
DB_SSL_MODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# Testes de integracao
DATABASE_URL=postgres://mecontrola:CHANGE_ME_USE_STRONG_PASSWORD@localhost:5432/mecontrola_db?sslmode=disable

# ---------------------------------------------------------------------------
# Observabilidade (OpenTelemetry)
# ---------------------------------------------------------------------------
# Stack local via docker compose sobe grafana/otel-lgtm:0.7.5 em localhost.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACE_SAMPLE_RATE=1.0
OTEL_SERVICE_VERSION=dev
LOG_LEVEL=debug
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Caddy (reverse proxy) — necessario apenas em producao
# ---------------------------------------------------------------------------
APP_DOMAIN=CHANGE_ME_yourdomain.com
CADDY_EMAIL=CHANGE_ME_your@email.com

# ---------------------------------------------------------------------------
# Deploy (usado por deployment/scripts/deploy.sh e GitHub Actions)
# ---------------------------------------------------------------------------
IMAGE_NAME=ghcr.io/limateixeiratecnologia/mecontrola
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# docker-compose local (grafana/otel-lgtm)
# ---------------------------------------------------------------------------
OTEL_LGTM_ADMIN_USER=admin
OTEL_LGTM_ADMIN_PASSWORD=admin@dev

# ---------------------------------------------------------------------------
# Backup offsite (pg-dump.sh) — producao
# ---------------------------------------------------------------------------
# rclone remote configurado com: rclone config
BACKUP_REMOTE=CHANGE_ME_backup:mecontrola-backups
# Gerar chave age: age-keygen -o key.txt  — armazenar fora do servidor
AGE_RECIPIENT=CHANGE_ME_age1...
RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Restore de backup (pg-restore-smoke.sh) — staging/validacao
# ---------------------------------------------------------------------------
AGE_KEY_FILE=CHANGE_ME_/etc/age/key.txt
RESTORE_PORT=15432
SMOKE_SCHEMA=mecontrola
ALERT_CMD=

# ---------------------------------------------------------------------------
# Outbox Transacional (RF-26 / D-03)
# ---------------------------------------------------------------------------
OUTBOX_DISPATCHER_ENABLED=true
OUTBOX_DISPATCHER_TICK_INTERVAL=500ms
OUTBOX_DISPATCHER_BATCH_SIZE=50
OUTBOX_DISPATCHER_HANDLER_TIMEOUT=10s
OUTBOX_RETRY_MAX_ATTEMPTS=15
OUTBOX_RETRY_BASE_BACKOFF=2s
OUTBOX_RETRY_MAX_BACKOFF=5m
OUTBOX_HOUSEKEEPING_RETENTION_DAYS=90
OUTBOX_HOUSEKEEPING_SCHEDULE=@daily
OUTBOX_REAPER_INTERVAL=@every 1m
OUTBOX_REAPER_STUCK_AFTER=5m

# ---------------------------------------------------------------------------
# Promtail / Grafana Cloud Loki — producao
# ---------------------------------------------------------------------------
LOKI_URL=CHANGE_ME_https://logs-prod-xxx.grafana.net/loki/api/v1/push
LOKI_USER_ID=CHANGE_ME_loki_user_id
LOKI_API_KEY=CHANGE_ME_loki_api_key

# ---------------------------------------------------------------------------
# KIWIFY
# ---------------------------------------------------------------------------
KIWIFY_API_BASE_URL=https://public-api.kiwify.com
KIWIFY_CLIENT_ID=CHANGE_ME_generate_secure_client_id
KIWIFY_CLIENT_SECRET=CHANGE_ME_generate_secure_secret_key_min_64_chars
KIWIFY_ACCOUNT_ID=CHANGE_ME_generate_secure_account_id
KIWIFY_PRODUCT_ID_MONTHLY=CHANGE_ME_product_id_monthly
KIWIFY_PRODUCT_ID_QUARTERLY=CHANGE_ME_product_id_quarterly
KIWIFY_PRODUCT_ID_ANNUAL=CHANGE_ME_product_id_annual
KIWIFY_WEBHOOK_SECRET=CHANGE_ME_generate_secure_webhook_secret
KIWIFY_WEBHOOK_SECRET_NEXT=
KIWIFY_WEBHOOK_TOKEN_HEADER=X-Kiwify-Webhook-Token
KIWIFY_OAUTH_TOKEN_SAFETY_MARGIN=5m
KIWIFY_RATE_LIMIT_MAX_REQUESTS_PER_MIN=100
KIWIFY_RATE_LIMIT_BURST=10
KIWIFY_RECONCILIATION_INTERVAL=@hourly
KIWIFY_RECONCILIATION_BATCH_SIZE=200
KIWIFY_HTTP_TIMEOUT=10s
KIWIFY_HTTP_RETRY_MAX_ATTEMPTS=3
KIWIFY_HTTP_RETRY_BACKOFF=1s

# ---------------------------------------------------------------------------
# Billing
# ---------------------------------------------------------------------------
BILLING_ENTITLEMENT_CACHE_CAPACITY=50000
BILLING_ENTITLEMENT_CACHE_TTL=5m
BILLING_ANONYMIZATION_SCHEDULE=@daily
BILLING_ANONYMIZATION_BATCH_SIZE=500
BILLING_ANONYMIZATION_RETENTION_DAYS=365
BILLING_KIWIFY_EVENTS_RETENTION_DAYS=90
BILLING_KIWIFY_EVENTS_HOUSEKEEPING_SCHEDULE=@daily
BILLING_KIWIFY_EVENTS_HOUSEKEEPING_BATCH=500
BILLING_GRACE_EXPIRATION_SCHEDULE=@daily

# ---------------------------------------------------------------------------
# Budgets
# ---------------------------------------------------------------------------
BUDGETS_PENDING_REAPER_INTERVAL=@every 30s
BUDGETS_PENDING_TTL_HOURS=24
BUDGETS_ABANDONED_DRAFT_CRON=0 3 * * *
BUDGETS_RETENTION_PURGE_CRON=0 4 1 * *
BUDGETS_RETENTION_PURGE_BATCH_SIZE=500

# ---------------------------------------------------------------------------
# Transactions
# ---------------------------------------------------------------------------
TRANSACTIONS_ENABLED=false
TRANSACTIONS_IDEMPOTENCY_TTL=24h
TRANSACTIONS_MONTHLY_SUMMARY_DEBOUNCE_WINDOW=1500ms
TRANSACTIONS_RECURRING_MATERIALIZER_CRON=@daily
TRANSACTIONS_MONTHLY_SUMMARY_RECONCILER_CRON=@daily
TRANSACTIONS_MONTHLY_SUMMARY_RECONCILER_LOOKBACK_HOURS=48
TRANSACTIONS_BRAZIL_TIMEZONE=America/Sao_Paulo

# ---------------------------------------------------------------------------
# Onboarding via Magic Token (E3)
# ---------------------------------------------------------------------------
ONBOARDING_TOKEN_TTL_DAYS=7
ONBOARDING_OUTREACH_GAP_HOURS=2
ONBOARDING_OUTREACH_ENABLED=false
ONBOARDING_CHECKOUT_CORS_ORIGINS=https://www.mecontrola.app.br,https://mecontrola.app.br
ONBOARDING_TRUSTED_PROXIES=127.0.0.1/32,::1/128
ONBOARDING_CHECKOUT_RATE_LIMIT_PER_MIN=10
ONBOARDING_CHECKOUT_RATE_LIMIT_BURST=5
ONBOARDING_STATE_RATE_LIMIT_PER_MIN=30
ONBOARDING_STATE_RATE_LIMIT_BURST=10
# Mapa plan_id=URL (um por linha, separado por newline)
ONBOARDING_KIWIFY_CHECKOUT_URLS=
ONBOARDING_KIWIFY_ALLOWED_HOSTS=pay.kiwify.com.br
ONBOARDING_META_RETENTION_DAYS=30
ONBOARDING_META_CLEANUP_SCHEDULE=30 3 * * *
ONBOARDING_TOKEN_EXPIRATION_SCHEDULE=0 3 * * *
ONBOARDING_MAX_TOKEN_LOOKUP_ATTEMPTS=5
ONBOARDING_TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_byte_token_encryption_key

# ---------------------------------------------------------------------------
# WhatsApp / Meta Cloud API (E3)
# ---------------------------------------------------------------------------
META_PHONE_NUMBER_ID=CHANGE_ME_meta_phone_number_id
META_ACCESS_TOKEN=CHANGE_ME_meta_access_token
META_APP_SECRET=CHANGE_ME_meta_app_secret
META_APP_SECRET_NEXT=
META_VERIFY_TOKEN=CHANGE_ME_meta_verify_token
META_OUTREACH_TEMPLATE_NAME=activation_reminder
META_BOT_NUMBER_E164=+5511900000000
META_BOT_NUMBER_DISPLAY=+55 11 9XXXX-XXXX
WA_MSG_WELCOME_ACTIVATED=Sua conta foi ativada com sucesso! Bem-vindo ao MeControla.
WA_MSG_ALREADY_ACTIVE=Sua conta ja esta ativa.
WA_MSG_CODE_ALREADY_USED_OTHER_ACCOUNT=Este codigo ja foi utilizado por outra conta.
WA_MSG_PAYMENT_STILL_PROCESSING_RETRY=Seu pagamento ainda esta sendo processado. Tente novamente em alguns minutos.
WA_MSG_CODE_EXPIRED_CONTACT_SUPPORT=Este codigo expirou. Entre em contato com o suporte.
WA_MSG_CODE_INVALID_CHECK_AGAIN=Codigo invalido. Verifique o link de ativacao e tente novamente.
WA_MSG_SYSTEM_UNAVAILABLE_RETRY=Sistema temporariamente indisponivel. Tente novamente em alguns minutos.
WA_MSG_PLEASE_USE_ATIVAR_COMMAND=Para ativar sua conta, envie: ATIVAR seguido do seu codigo de ativacao.
WA_MSG_INVALID_COUNTRY=Numero de telefone nao suportado. Apenas numeros brasileiros sao aceitos.
WA_MSG_AGENT_STUB_RECEIVED=MeControla recebeu sua mensagem — estamos preparando sua experiencia.
WHATSAPP_WEBHOOK_RATE_LIMIT_PER_MIN=600
WHATSAPP_WEBHOOK_RATE_LIMIT_BURST=100

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=CHANGE_ME_telegram_bot_token
TELEGRAM_BOT_ID=0
TELEGRAM_BOT_USERNAME=CHANGE_ME_bot_username
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_SECRET_TOKEN=CHANGE_ME_telegram_secret_token
TELEGRAM_SECRET_TOKEN_NEXT=
TELEGRAM_WEBHOOK_PATH=/api/v1/channels/telegram/webhook
TELEGRAM_WEBHOOK_RATE_LIMIT_PER_MIN=600
TELEGRAM_WEBHOOK_RATE_LIMIT_BURST=100
TELEGRAM_OUTBOUND_TIMEOUT=10s
TELEGRAM_MSG_AGENT_STUB_RECEIVED=MeControla recebeu sua mensagem — estamos preparando sua experiencia.
TELEGRAM_MSG_ONBOARDING_FALLBACK=Para ativar sua conta, abra o link enviado por e-mail e siga as instrucoes.
TELEGRAM_MSG_WELCOME_ACTIVATED=Sua conta foi vinculada ao Telegram com sucesso! Pode comecar a mandar suas mensagens financeiras por aqui.
TELEGRAM_MSG_ALREADY_ACTIVE=Seu Telegram ja esta vinculado a sua conta MeControla.
TELEGRAM_MSG_REQUIRES_WHATSAPP_ACTIVATION=Antes de usar o Telegram, ative sua conta no WhatsApp com o codigo recebido.
TELEGRAM_MSG_CODE_ALREADY_USED_OTHER_ACCOUNT=Este codigo ja foi utilizado por outra conta. Se voce nao reconhece, entre em contato com o suporte.
TELEGRAM_MSG_PAYMENT_STILL_PROCESSING_RETRY=Seu pagamento ainda esta sendo processado. Tente novamente em alguns minutos.
TELEGRAM_MSG_CODE_EXPIRED_CONTACT_SUPPORT=Este codigo expirou. Entre em contato com o suporte.
TELEGRAM_MSG_CODE_INVALID_CHECK_AGAIN=Codigo invalido. Verifique se digitou ATIVAR seguido do codigo correto.
TELEGRAM_MSG_SYSTEM_UNAVAILABLE_RETRY=Sistema temporariamente indisponivel. Tente novamente em alguns minutos.
TELEGRAM_MSG_PLEASE_USE_ATIVAR_COMMAND=Para vincular seu Telegram, envie ATIVAR seguido do codigo recebido por e-mail.

# ---------------------------------------------------------------------------
# Agent / LLM (OpenRouter)
# ---------------------------------------------------------------------------
AGENT_MODE=stub
OPENROUTER_BASE_URL=https://openrouter.ai
OPENROUTER_API_KEY=CHANGE_ME_openrouter_api_key
AGENT_LLM_HTTP_REFERER=https://mecontrola.app
AGENT_LLM_X_TITLE=MeControla
AGENT_LLM_PRIMARY_MODEL=google/gemini-2.5-flash-lite
AGENT_LLM_FALLBACK_MODELS=openai/gpt-5-nano,mistralai/mistral-small-3.2-24b-instruct,anthropic/claude-haiku-4.5
AGENT_LLM_MAX_TOKENS=256
AGENT_LLM_TEMPERATURE=0
AGENT_LLM_REQUEST_TIMEOUT=8s
AGENT_LLM_PROMPT_PAD_TOKENS=1100
AGENT_LLM_CIRCUIT_FAILURES=5
AGENT_LLM_CIRCUIT_WINDOW=30s
AGENT_LLM_CIRCUIT_COOLDOWN=60s

# ---------------------------------------------------------------------------
# Gateway Authentication (B1 — HMAC-SHA256 LLM -> API)
# ---------------------------------------------------------------------------
# Hex lowercase de 32 bytes (256 bits) gerado via: openssl rand -hex 32
# CURRENT obrigatorio em ENVIRONMENT=production; NEXT opcional (rotacao current/next)
IDENTITY_GATEWAY_SHARED_SECRET_CURRENT=CHANGE_ME_openssl_rand_hex_32
IDENTITY_GATEWAY_SHARED_SECRET_NEXT=
# Janela de aceite de timestamp (duration; default 60s)
IDENTITY_GATEWAY_AUTH_WINDOW=60s
IDENTITY_AUTH_EVENTS_HOUSEKEEPING_SCHEDULE=@daily
IDENTITY_AUTH_EVENTS_HOUSEKEEPING_BATCH=500
IDENTITY_AUTH_EVENTS_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# PgBouncer — connection pooler (producao)
# ---------------------------------------------------------------------------
# Em producao: DB_HOST=pgbouncer DB_PORT=6432 (override no compose.prod.yml)
# O bitnami/pgbouncer usa as variaveis DB_USER/DB_PASSWORD/DB_NAME acima.
# Para gerar userlist.txt: ver deployment/pgbouncer/userlist.txt.example

# ---------------------------------------------------------------------------
# PostgreSQL customizado com pgBackRest (producao)
# ---------------------------------------------------------------------------
# Para usar Dockerfile.postgres (com pgBackRest instalado):
POSTGRES_IMAGE=postgres:16-alpine

# ---------------------------------------------------------------------------
# pgBackRest — backup PITR com S3-compatible (producao)
# ---------------------------------------------------------------------------
PGBACKREST_S3_ENDPOINT=CHANGE_ME_s3.us-east-1.amazonaws.com
PGBACKREST_S3_BUCKET=CHANGE_ME_meu-bucket-backups
PGBACKREST_S3_REGION=us-east-1
PGBACKREST_S3_KEY=CHANGE_ME_s3_access_key
PGBACKREST_S3_KEY_SECRET=CHANGE_ME_s3_secret_key

# ---------------------------------------------------------------------------
# Caddy com rate limiting (producao)
# ---------------------------------------------------------------------------
# Para usar Dockerfile.caddy (xcaddy + mholt/caddy-ratelimit):
CADDY_IMAGE=caddy:2-alpine
# Limite global por IP (requests/minuto)
CADDY_RATE_LIMIT_REQUESTS=100
# Limite em endpoints de autenticação por IP (requests/minuto)
CADDY_RATE_LIMIT_AUTH=20

# ---------------------------------------------------------------------------
# AlertManager — SMTP (producao)
# ---------------------------------------------------------------------------
ALERTMANAGER_FROM_EMAIL=CHANGE_ME_alerts@yourdomain.com
ALERTMANAGER_TO_EMAIL=CHANGE_ME_oncall@yourdomain.com
ALERTMANAGER_SMTP_HOST=CHANGE_ME_smtp.yourdomain.com
ALERTMANAGER_SMTP_USER=CHANGE_ME_smtp_user
ALERTMANAGER_SMTP_PASSWORD=CHANGE_ME_smtp_password

# ---------------------------------------------------------------------------
# Grafana local (observability profile)
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_use_strong_password
IDENTITY_AUTH_EVENTS_RETENTION_DAYS=90
