{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/validate-preload.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/validate-governance.sh"
          }
        ]
      }
    ]
  }
}
