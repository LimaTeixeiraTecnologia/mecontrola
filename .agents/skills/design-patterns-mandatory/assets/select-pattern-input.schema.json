{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SelectPatternInput",
  "type": "object",
  "required": ["problem", "signals"],
  "properties": {
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "force_reject": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
