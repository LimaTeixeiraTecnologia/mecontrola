{
  "id": null,
  "uid": "budgets-module-v1",
  "title": "Budgets Module",
  "description": "Dashboard operacional do modulo budgets (prd-budgets-monthly). Cobre metricas RED por rota, pending events reaper, retention purge, abandoned drafts e alertas de threshold via OpenTelemetry.",
  "tags": ["budgets", "expenses", "otel", "monthly"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "job",
        "type": "query",
        "datasource": "${datasource}",
        "label": "Job",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "query": "label_values(http_server_request_duration_seconds_count{route=~\"/api/v1/budgets.*\"}, job)",
        "current": {}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${datasource}",
        "label": "Instance",
        "hide": 0,
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "query": "label_values(http_server_request_duration_seconds_count{job=\"$job\", route=~\"/api/v1/budgets.*\"}, instance)",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Route (/api/v1/budgets*)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(http_server_request_duration_seconds_count{job=\"$job\", instance=~\"$instance\", route=~\"/api/v1/budgets.*\"}[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate by Route (/api/v1/budgets*)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(http_server_request_duration_seconds_count{job=\"$job\", instance=~\"$instance\", route=~\"/api/v1/budgets.*\", http_response_status_code=~\"5..\"}[5m])) / sum by (route, method) (rate(http_server_request_duration_seconds_count{job=\"$job\", instance=~\"$instance\", route=~\"/api/v1/budgets.*\"}[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 Latency by Route (/api/v1/budgets*)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (route, method, le) (rate(http_server_request_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\", route=~\"/api/v1/budgets.*\"}[5m])))",
          "legendFormat": "p95 {{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "p99 Latency by Route (/api/v1/budgets*)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (route, method, le) (rate(http_server_request_duration_seconds_bucket{job=\"$job\", instance=~\"$instance\", route=~\"/api/v1/budgets.*\"}[5m])))",
          "legendFormat": "p99 {{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pending Events Reaper — Processed Total",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(budgets_pending_events_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "processed/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(budgets_pending_events_applied_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "applied/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(budgets_pending_events_expired_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "expired/s",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Abandoned Drafts Signaled",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"] }
      },
      "targets": [
        {
          "expr": "sum by (competence) (rate(budgets_abandoned_drafts_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{competence}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Retention Purge",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"] }
      },
      "targets": [
        {
          "expr": "sum by (table) (rate(budgets_retention_purged_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "purged {{table}}/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(budgets_retention_purge_deferred_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "deferred/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Expense Committed Consumer Failures",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(budgets_expense_committed_consumer_decode_failed_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "decode_failed/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "External Expense Consumer Failures",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"] }
      },
      "targets": [
        {
          "expr": "sum(rate(budgets_external_expense_consumer_decode_failed_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "decode_failed/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(budgets_external_expense_consumer_source_rejected_total{job=\"$job\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "source_rejected/s",
          "refId": "B"
        }
      ]
    }
  ]
}
