              "path": ["api", "v1", "budgets", "alerts"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "competence", "value": "{{competence}}" },
                { "key": "root_slug", "value": "essentials", "disabled": true },
                { "key": "threshold", "value": "80", "disabled": true, "description": "50|80|100" },
                { "key": "cursor", "value": "", "disabled": true }
              ]
