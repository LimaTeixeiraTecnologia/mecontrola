    {
      "name": "7. WhatsApp Webhook (Meta)",
      "description": "Webhook de mensagens do WhatsApp Business (Meta).\n\n- `GET /api/v1/whatsapp/verify` — verificação (hub.mode/hub.verify_token/hub.challenge).\n- `POST /api/v1/whatsapp/inbound` — assinatura `X-Hub-Signature-256: sha256=<hex>` (HMAC sobre body raw com `whatsapp_app_secret`).",
      "item": [
        {
          "name": "Verify",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/whatsapp/verify?hub.mode=subscribe&hub.verify_token={{whatsapp_verify_token}}&hub.challenge=challenge-123",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "whatsapp", "verify"],
              "query": [
                { "key": "hub.mode", "value": "subscribe" },
                { "key": "hub.verify_token", "value": "{{whatsapp_verify_token}}" },
                { "key": "hub.challenge", "value": "challenge-123" }
              ]
            },
            "description": "Resposta: 200 com `hub.challenge` em texto puro quando o token bate; 403 caso contrário."
          }
        },
        {
          "name": "Inbound",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.request.body.raw || '';",
                  "const secret = pm.environment.get('whatsapp_app_secret') || '';",
                  "const sig = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                  "pm.environment.set('whatsapp_sig', 'sha256=' + sig);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "X-Hub-Signature-256", "value": "{{whatsapp_sig}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"WABA-ID\",\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": { \"display_phone_number\": \"5511988887777\", \"phone_number_id\": \"PNID\" },\n            \"contacts\": [{ \"profile\": { \"name\": \"Ana\" }, \"wa_id\": \"5511999990001\" }],\n            \"messages\": [\n              {\n                \"from\": \"5511999990001\",\n                \"id\": \"wamid.HBgM...AA==\",\n                \"timestamp\": \"1749643200\",\n                \"type\": \"text\",\n                \"text\": { \"body\": \"ativar\" }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/whatsapp/inbound",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "whatsapp", "inbound"]
            },
            "description": "Recebe eventos da Meta. Resposta sempre `200 OK` quando processado (sucesso ou descartado intencionalmente)."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Override de fallback caso o environment não esteja selecionado."
    }
  ]
