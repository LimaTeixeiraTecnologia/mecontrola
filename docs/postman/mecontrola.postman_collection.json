    {
      "name": "5. Budgets",
      "description": "Orçamentos mensais (`competence` no formato YYYY-MM), recorrência, despesas e alertas. Exige `X-User-ID`.",
      "item": [
        {
          "name": "Criar orçamento (draft)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-User-ID", "value": "{{user_id}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"competence\": \"{{competence}}\",\n  \"total_cents\": 500000,\n  \"allocations\": [\n    { \"root_slug\": \"essentials\", \"basis_points\": 5000 },\n    { \"root_slug\": \"lifestyle\", \"basis_points\": 3000 },\n    { \"root_slug\": \"savings\",   \"basis_points\": 2000 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", ""]
            },
            "description": "Cria orçamento em `draft`. A soma das alocações deve ser ≤ 10000 basis points (100%).\n\n**Erros:** 400 `validation_error`, 409 `budget_conflict`, 422 `validation_error`."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Location", "value": "/api/v1/budgets/2026-06" }
              ],
              "body": "{\n  \"id\": \"b1d3a... \",\n  \"competence\": \"2026-06\",\n  \"total_cents\": 500000,\n  \"status\": \"draft\",\n  \"allocations\": [\n    { \"root_slug\": \"essentials\", \"basis_points\": 5000 },\n    { \"root_slug\": \"lifestyle\",  \"basis_points\": 3000 },\n    { \"root_slug\": \"savings\",    \"basis_points\": 2000 }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Ativar orçamento",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-User-ID", "value": "{{user_id}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/{{competence}}/activate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "{{competence}}", "activate"]
            },
            "description": "Promove o draft a ativo (a soma deve ser exatamente 10000 e total > 0).\n\n**Erros:** 404 `budget_not_found`, 409 `budget_already_active`, 422 `activation_invalid`."
          }
        },
        {
          "name": "Excluir orçamento (draft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "X-User-ID", "value": "{{user_id}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/{{competence}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "{{competence}}"]
            },
            "description": "Apenas drafts podem ser excluídos. **Erros:** 404, 409 `budget_active_conflict`."
          }
        },
        {
          "name": "Resumo mensal",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-User-ID", "value": "{{user_id}}", "type": "text" }],
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/{{competence}}/summary",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "{{competence}}", "summary"]
            },
            "description": "Totais consolidados de despesas vs alocações por root_slug.\n\n**Erros:** 404 `budget_not_found`."
          }
        },
        {
          "name": "Criar recorrência",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-User-ID", "value": "{{user_id}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_competence\": \"{{competence}}\",\n  \"months\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/recurrence",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "recurrence"]
            },
            "description": "Replica o orçamento da competência de origem para `months` meses subsequentes.\n\n**Resposta:** 207 Multi-Status — relatório por mês criado/conflitado.\n**Erros:** 422 `recurrence_invalid`."
          }
        },
        {
