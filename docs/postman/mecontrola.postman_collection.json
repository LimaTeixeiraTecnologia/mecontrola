                  "try {",
                  "  const body = pm.response.json();",
                  "  const first = body && (body.items || body.categories || [])[0];",
                  "  if (first && first.id) { pm.environment.set('category_id', first.id); }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
