              { "key": "X-User-ID", "value": "{{user_id}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_transaction_id\": \"{{external_transaction_id}}\",\n  \"subcategory_id\": \"{{subcategory_id}}\",\n  \"competence\": \"{{competence}}\",\n  \"amount_cents\": 8990,\n  \"occurred_at\": \"2026-06-10T14:25:00Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/expenses",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "expenses"]
            },
            "description": "Upsert idempotente pela tripla (user_id, source=api, external_transaction_id).\n\n**Erros:** 400 `validation_error`, 409 `expense_version_conflict`/`expense_tombstone_conflict`."
          }
        },
        {
          "name": "Atualizar despesa",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "X-User-ID", "value": "{{user_id}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_transaction_id\": \"{{external_transaction_id}}\",\n  \"subcategory_id\": \"{{subcategory_id}}\",\n  \"competence\": \"{{competence}}\",\n  \"amount_cents\": 9990,\n  \"occurred_at\": \"2026-06-10T14:25:00Z\",\n  \"expected_version\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/expenses/{{external_transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "expenses", "{{external_transaction_id}}"]
            },
            "description": "Requer `expected_version` (optimistic locking).\n\n**Erros:** 400/422 `version_required`, 404, 409 conflict."
          }
        },
        {
          "name": "Excluir despesa",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-User-ID", "value": "{{user_id}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expected_version\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/budgets/expenses/{{external_transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "budgets", "expenses", "{{external_transaction_id}}"]
            },
            "description": "Soft delete via tombstone com `expected_version`."
          }
        }
      ]
    },
    {
      "name": "6. Categories",
      "description": "Catálogo de categorias e dicionário. Exige `X-User-ID`. Suporta ETag/If-None-Match para cache.",
