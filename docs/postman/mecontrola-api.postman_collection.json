    {
      "name": "02 — Onboarding",
      "item": [
        {
          "name": "POST /api/v1/onboarding/checkout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_id\": \"monthly\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/onboarding/checkout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "onboarding",
                "checkout"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Tem checkout_url\", () => pm.expect(pm.response.json()).to.have.property(\"checkout_url\"));",
                  "const body = pm.response.json();",
                  "if (body.checkout_url) {",
                  "  pm.environment.set(\"onboarding_checkout_url\", body.checkout_url);",
                  "  const url = new URL(body.checkout_url);",
                  "  const token = url.searchParams.get(\"sck\") || \"\";",
                  "  pm.test(\"checkout_url contem sck\", () => pm.expect(token).to.be.a(\"string\").and.not.empty);",
                  "  pm.environment.set(\"onboarding_token\", token);",
                  "  pm.environment.set(\"funnel_token\", token);",
                  "}",
                  "pm.environment.set(\"expected_ready_to_activate\", \"false\");",
                  "pm.environment.unset(\"wa_me_url\");"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/onboarding/tokens/:token/state",
          "request": {
            "method": "GET",
            "header": [

            ],
            "url": {
              "raw": "{{base_url}}/api/v1/onboarding/tokens/{{onboarding_token}}/state",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "onboarding",
                "tokens",
                "{{onboarding_token}}",
                "state"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Tem ready_to_activate\", () => pm.expect(pm.response.json()).to.have.property(\"ready_to_activate\"));",
                  "pm.test(\"ready_to_activate é boolean\", () => pm.expect(pm.response.json().ready_to_activate).to.be.a(\"boolean\"));",
                  "const body = pm.response.json();",
                  "const expectedRaw = (pm.environment.get(\"expected_ready_to_activate\") || \"\").trim().toLowerCase();",
                  "if (expectedRaw === \"true\" || expectedRaw === \"false\") {",
                  "  const expected = expectedRaw === \"true\";",
                  "  pm.test(`ready_to_activate=${expected}`, () => pm.expect(body.ready_to_activate).to.equal(expected));",
                  "}",
                  "if (body.wa_me_url) pm.environment.set(\"wa_me_url\", body.wa_me_url);"
                ]
              }
            }
          ]
        }
      ]
