  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const resolve = (v) => pm.variables.replaceIn(v || '');",
          "const upsertHeader = (key, value) => { if (value === undefined || value === null || value === '') return; if (pm.request.headers.has(key)) { pm.request.headers.upsert({ key, value }); } else { pm.request.headers.add({ key, value }); } };",
          "const rawUrl = resolve(pm.request.url.toString());",
          "const rawBody = pm.request.body && pm.request.body.mode === 'raw' ? resolve(pm.request.body.raw) : '';",
          "const gatewaySecret = pm.environment.get('gateway_secret');",
          "const userId = pm.environment.get('user_id');",
          "if (gatewaySecret && userId && gatewaySecret.length >= 64) {",
          "  const timestamp = String(Math.floor(Date.now() / 1000));",
          "  pm.environment.set('gateway_timestamp', timestamp);",
          "  const secretBytes = CryptoJS.enc.Hex.parse(gatewaySecret);",
          "  const message = userId.toLowerCase() + '.' + timestamp;",
          "  const sig = CryptoJS.HmacSHA256(message, secretBytes).toString(CryptoJS.enc.Hex);",
          "  pm.environment.set('gateway_auth', sig);",
          "}",
          "if (rawUrl.includes('/api/v1/billing/webhooks/kiwify')) {",
          "  const secret = pm.environment.get('kiwify_webhook_secret');",
          "  if (secret) {",
          "    const sig = CryptoJS.HmacSHA1(rawBody, secret).toString(CryptoJS.enc.Hex);",
          "    pm.environment.set('kiwify_signature', sig);",
          "    upsertHeader('X-Kiwify-Signature', sig);",
          "  }",
          "}",
          "if (rawUrl.includes('/api/v1/whatsapp/inbound') || rawUrl.includes('/api/v1/whatsapp/status')) {",
          "  const secret = pm.environment.get('meta_app_secret');",
          "  if (secret) {",
          "    const sig = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
          "    const headerValue = 'sha256=' + sig;",
          "    pm.environment.set('meta_signature', headerValue);",
          "    upsertHeader('X-Hub-Signature-256', headerValue);",
          "  }",
          "}"
        ]
      }
    }
  ],
