{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Visão geral do módulo transactions (CRUD unificado). Fonte única do resumo mensal (crédito somado apenas via fatura). Sem séries card_purchase (superfície removida — RF-24).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Fator de coalescing do recompute mensal por ref_months_affected.",
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {},
      "title": "Recompute mensal — coalesce factor",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg_over_time(transactions_monthly_summary_coalesce_factor[5m])",
          "legendFormat": "coalesce_factor",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Lag p95 do outbox para eventos transactions.transaction.*.",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {},
      "title": "Outbox lag p95 — transactions.transaction.*",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(outbox_lag_seconds_bucket{event_type=~\"transactions.transaction..*\"}[5m])) by (le, event_type))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Taxa de eventos de transação publicados por tipo (created/updated/deleted).",
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {},
      "title": "Eventos de transação publicados",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(outbox_published_total{event_type=~\"transactions.transaction..*\"}[5m])) by (event_type)",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Guarda de regressão: eventos legados transactions.card_purchase.* devem permanecer em zero após o corte (RF-24).",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {},
      "title": "Guarda card_purchase legado (deve ser 0)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(outbox_published_total{event_type=~\"transactions.card_purchase..*\"}[15m]))",
          "legendFormat": "card_purchase legado",
          "refId": "A"
        }
      ],
      "type": "stat"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["transactions", "prd-transactions-crud-unificado"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Transactions — Visão Geral (CRUD Unificado)",
  "uid": "transactions-overview",
  "version": 1
}
