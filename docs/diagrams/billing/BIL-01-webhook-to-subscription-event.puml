@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Billing - BIL-01 Webhook Kiwify to subscription event

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Ext(kiwify, "Kiwify", "Gateway de pagamento e assinaturas")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Recebe webhook Kiwify e executa o modulo billing")
  ContainerDb(billingDb, "Billing Store", "PostgreSQL", "kiwify_events, plans, subscriptions e processed_events")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "Persistencia de billing.subscription.*")
  Container(workerProc, "Background Worker", "Go", "Consome envelopes publicados pelo billing")
}

Rel(kiwify, apiServer, "[sync] POST /api/v1/billing/webhooks/kiwify", "HTTPS webhook", $tags="sync")
Rel(apiServer, billingDb, "[sync] audita envelope, marca processed_event, resolve plan e faz upsert de subscription", "SQL", $tags="sync")
Rel(apiServer, outboxStore, "[async] publica billing.subscription.activated|renewed|past_due|canceled|refunded", "SQL insert", $tags="async")
Rel(workerProc, outboxStore, "[async] consome envelope para modulos downstream", "dispatcher poll", $tags="async")

SHOW_LEGEND()
@enduml
