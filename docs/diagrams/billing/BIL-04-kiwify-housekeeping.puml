@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Billing - BIL-04 Kiwify events housekeeping

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

System_Boundary(mecontrola, "MeControla") {
  Container(workerProc, "Background Worker", "Go", "Executa o job billing-kiwify-events-housekeeping")
  ContainerDb(billingDb, "Billing Audit Store", "PostgreSQL", "Tabela kiwify_events")
}

Rel(workerProc, billingDb, "[sync] remove envelopes auditados antigos", "SQL delete", $tags="sync")

SHOW_LEGEND()
@enduml
