@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Billing - BIL-05 Notification consumer

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "billing.subscription.past_due|refunded|expired_after_grace")
  Container(workerProc, "Background Worker", "Go", "Despacha envelope para NotificationHandler")
  Container(billingRuntime, "Billing Event Handler", "Go", "Executa SendSubscriptionNotification")
}

Rel(workerProc, outboxStore, "[async] consome eventos de assinatura publicados pelo proprio billing", "dispatcher poll", $tags="async")
Rel(workerProc, billingRuntime, "[sync] entrega payload para NotificationHandler", "in-process", $tags="sync")

SHOW_LEGEND()
@enduml
