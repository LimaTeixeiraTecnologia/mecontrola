@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Billing - BIL-03 Grace expiration

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  Container(workerProc, "Background Worker", "Go", "Executa o job billing-grace-expiration")
  ContainerDb(billingDb, "Billing Store", "PostgreSQL", "Subscriptions com grace_end")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "billing.subscription.expired_after_grace")
}

Rel(workerProc, billingDb, "[sync] encontra subscriptions apos grace_end e atualiza estado", "SQL", $tags="sync")
Rel(workerProc, outboxStore, "[async] publica billing.subscription.expired_after_grace", "SQL insert", $tags="async")

SHOW_LEGEND()
@enduml
