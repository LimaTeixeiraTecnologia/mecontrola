@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Billing - BIL-02 Reconciliation

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Ext(kiwify, "Kiwify API", "Consulta de sales atualizadas")

System_Boundary(mecontrola, "MeControla") {
  Container(workerProc, "Background Worker", "Go", "Executa o job billing-reconciliation")
  ContainerDb(billingDb, "Billing Store", "PostgreSQL", "checkpoints, subscriptions e processed_events")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "Eventos de correcao de assinatura")
}

Rel(workerProc, billingDb, "[sync] le checkpoint, corrige subscriptions e atualiza processed_events", "SQL", $tags="sync")
Rel(workerProc, kiwify, "[sync] ListSalesUpdatedSince(window, page)", "HTTPS API", $tags="sync")
Rel(workerProc, outboxStore, "[async] publica billing.subscription.* quando encontra divergencia corrigivel", "SQL insert", $tags="async")

SHOW_LEGEND()
@enduml
