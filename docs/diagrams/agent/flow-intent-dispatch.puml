@startuml Agent - Fluxo: Mensagem → LLM → Intent → Dispatch → Reply
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Dynamic.puml

title Agent — Fluxo 1: Mensagem Natural → LLM → Intent → Execução → Resposta

Person(user, "Usuário")
System_Ext(channel, "WhatsApp / Telegram")
Container(worker, "Worker / HandleInboundMessage", "Go", "")
System_Ext(categories, "Categories Module")
System_Ext(cards, "Card Module")
System_Ext(openrouter, "OpenRouter API")
System_Ext(transactions, "Transactions Module")
ContainerDb(postgres, "PostgreSQL", "", "")
ContainerQueue(outbox, "Outbox", "", "")

Rel(user, channel, "1. 'Gastei R$ 89 no Rappi'")
Rel(channel, worker, "2. buildWhatsAppAgentRoute() /\nbuildTelegramAgentRoute()\n{ userID, channel, text }")
Rel(worker, categories, "3. PromptContextLoader:\nGET /api/v1/categories")
Rel(worker, cards, "4. PromptContextLoader:\nGET /api/v1/cards")
Rel(worker, worker, "5. PromptBuilder:\ncria systemPrompt com catálogo,\ncartões e permissões do usuário")
Rel(worker, openrouter, "6. LLMProvider.Interpret\n{ model: ModelSlug,\n  system: '[contexto estruturado]',\n  user: 'Gastei R$ 89 no Rappi' }")
Rel(openrouter, worker, "7. JSON estruturado:\n{ module: 'transactions',\n  action: 'create_transaction',\n  params: { amountCents: 8900,\n    categoryID: 'food-delivery',\n    direction: 'outcome' } }")
Rel(worker, worker, "8. IntentValidator:\nvalida JSON contra schema esperado")
Rel(worker, transactions, "9. IntentDispatcher.Dispatch:\nPOST /api/v1/transactions\n{ amountCents: 8900, ... }")
Rel(worker, postgres, "10. INSERT agent_events\n{ outcome: 'routed', provider: 'claude',\n  promptTokens, completionTokens, latencyMS }")
Rel(worker, outbox, "11. Publica agent.intent.executed.v1")
Rel(worker, channel, "12. 'Registrei R$ 89,00 em\nDelivery de Comida ✓'")
Rel(channel, user, "13. Mensagem de confirmação")

@enduml
