@startuml Agent - Container Diagram [GERAL]
' ============================================================
' VISÃO GERAL — Agents Module (port weather sobre o substrato platform)
' Containers, atores externos, LLM provider, tools e memória.
' Sem endpoints HTTP diretos — acionado via canal WhatsApp.
' ============================================================
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Agents — C4 Container View (Geral)

Person(user, "Usuário", "Envia mensagens em linguagem natural\nvia WhatsApp.")
System_Ext(wa_channel, "WhatsApp Cloud API", "Canal único de entrada/saída de mensagens.\nMeta Graph API.")
System_Ext(openrouter, "OpenRouter API", "Provider único de LLM.\nhttps://openrouter.ai/api/v1/chat/completions\nModelo configurável (llm.NewOpenRouterProvider).\nSem circuit breaker / fallback chain.")
System_Ext(weather_api, "Weather Client", "Adapter externo consumido pela weather tool.")

System_Boundary(agents, "Agents Module") {

  Container(consumer, "WhatsApp Inbound Consumer", "Go", "Consome o evento agents.whatsapp.inbound.v1\npublicado por buildWhatsAppAgentRoute.\n--\nNewWhatsAppInboundConsumer:\n  → usecases.HandleInbound.Execute\n  → AgentRuntime.Execute\n  → responde via WhatsApp gateway")

  Container(runtime, "AgentRuntime", "Go", "internal/platform/agent/runtime.go\n--\nExecute(InboundRequest):\n  1. ThreadGateway.GetOrCreate\n     (Thread por resourceId/threadId)\n  2. RunStore.Insert (Run, RunStatusRunning)\n  3. WorkingMemory.Get + MessageStore.Recent\n     (monta system prompt + histórico)\n  4. AgentRegistry.Resolve(agentID)\n  5. Agent.Execute\n  6. MessageStore.Append (user + assistant)\n  7. closeRun (RunStatusSucceeded/Failed)")

  Container(agentcore, "Agent (loop tool-calling)", "Go", "internal/platform/agent/agent.go\n--\ncompleteWithTools (máx 5 rounds):\n  llm.Provider.Complete →\n  se ToolCalls: tool.ToolHandle.Invoke →\n  realimenta mensagens → repete\nSem ToolCalls: retorna Result")

  ContainerDb(postgres, "PostgreSQL", "PostgreSQL 16 + pgvector", "Persistência do substrato.\n--\nThreads, Messages, WorkingMemory,\nSemanticRecall (embeddings),\nRuns (auditoria), platform_scorer_results")

  ContainerQueue(outbox, "Outbox", "PostgreSQL table", "Entrega de eventos.\n--\nagents.whatsapp.inbound.v1\nindexação assíncrona de embeddings")
}

Rel(user, wa_channel, "Mensagem em linguagem natural", "WhatsApp")
Rel(wa_channel, outbox, "buildWhatsAppAgentRoute publica\nagents.whatsapp.inbound.v1", "SQL INSERT")
Rel(outbox, consumer, "Dispatch do evento inbound", "Internal event")
Rel(consumer, runtime, "HandleInbound → Execute", "Internal call")
Rel(runtime, postgres, "Thread / Run / Message / WorkingMemory", "SQL")
Rel(runtime, agentcore, "Agent.Execute(Request)", "Internal call")
Rel(agentcore, openrouter, "llm.Provider.Complete\n{ model, messages, tools }\nAuthorization: Bearer $OPENROUTER_API_KEY", "HTTPS/JSON")
Rel(agentcore, weather_api, "tool.ToolHandle.Invoke", "Internal call")
Rel(consumer, wa_channel, "Envia resposta ao usuário", "WhatsApp")

@enduml
