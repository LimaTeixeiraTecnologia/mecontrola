@startuml Budgets - Fluxo: DRAFT → ACTIVE → Despesas → Alertas
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Dynamic.puml

title Budgets — Fluxo 1: Criação, Ativação e Avaliação de Alertas

Person(user, "Usuário")
Container(http_api, "HTTP API", "Go/Chi", "")
ContainerDb(postgres, "PostgreSQL", "", "")
ContainerQueue(outbox, "Outbox", "", "")
Container(worker, "Worker / EvaluateAlert", "Go", "")

Rel(user, http_api, "1. POST /api/v1/budgets\n{ competence: '2026-06',\n  totalCents: 500000,\n  allocations: [{ categorySlug, basisPoints }] }")
Rel(http_api, http_api, "2. Valida soma de basisPoints = 10.000 (100%)")
Rel(http_api, postgres, "3. INSERT budget (status=DRAFT)\nINSERT budget_allocations")
Rel(user, http_api, "4. PATCH /api/v1/budgets/2026-06/activate")
Rel(http_api, postgres, "5. Transita DRAFT → ACTIVE\n(409 Conflict se já existe ACTIVE)")
Rel(user, http_api, "6. POST /api/v1/budgets/expenses\n{ competence: '2026-06', subcategoryID, amountCents }")
Rel(http_api, postgres, "7. UpsertExpense: INSERT/UPDATE budget_expenses")
Rel(http_api, outbox, "8. Publica budgets.expense.committed.v1\n{ userID, competence, subcategoryID,\n  rootSlug, mutationKind }")
Rel(outbox, worker, "9. Consumer: EvaluateAlert")
Rel(worker, postgres, "10. Calcula:\n    totalGasto / allocatedCents × 100 = %gasto")
Rel(worker, postgres, "11. Se % > threshold:\n    upsert budget_alert { competence, categorySlug, pct }")
Rel(user, http_api, "12. GET /api/v1/budgets/{competence}/summary\n(resumo do mês com % gasto por categoria)\nGET /api/v1/budgets/alerts?threshold=80\n(categorias com gasto > 80%)")

@enduml
