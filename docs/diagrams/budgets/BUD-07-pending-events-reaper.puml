@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Budgets - BUD-07 Pending events reaper

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  Container(workerProc, "Background Worker", "Go", "Executa o job budgets-pending-events-reaper")
  ContainerDb(budgetsDb, "Budgets Store", "PostgreSQL", "pending_events e expenses")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "budgets.expense.committed.v1")
}

Rel(workerProc, budgetsDb, "[sync] le pending_events e reaplica mutacoes em expenses", "SQL", $tags="sync")
Rel(workerProc, outboxStore, "[async] republica budgets.expense.committed.v1 quando resolve a pendencia", "SQL insert", $tags="async")

SHOW_LEGEND()
@enduml
