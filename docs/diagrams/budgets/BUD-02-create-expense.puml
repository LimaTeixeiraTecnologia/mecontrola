@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Budgets - BUD-02 Create expense

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

Person(apiClient, "API Client", "Cliente autenticado")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa POST /api/v1/budgets/expenses")
  Container(categoriesRuntime, "Categories Reader", "Go", "Valida subcategoria e resolve root_slug")
  ContainerDb(budgetsDb, "Budgets Store", "PostgreSQL", "expenses e budgets auto-draft")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "budgets.expense.committed.v1")
  Container(workerProc, "Background Worker", "Go", "Consumidor posterior do evento")
}

Rel(apiClient, apiServer, "[sync] POST /api/v1/budgets/expenses", "HTTPS/JSON", $tags="sync")
Rel(apiServer, categoriesRuntime, "[sync] validate subcategory and resolve root_slug", "in-process adapter", $tags="sync")
Rel(apiServer, budgetsDb, "[sync] cria expense e auto-draft se necessario", "SQL", $tags="sync")
Rel(apiServer, outboxStore, "[async] publica budgets.expense.committed.v1", "SQL insert", $tags="async")
Rel(workerProc, outboxStore, "[async] consome evento para alertas", "dispatcher poll", $tags="async")

SHOW_LEGEND()
@enduml
