@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Budgets - BUD-06 Ingest external expense

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "external.expense.v1 e budgets.expense.committed.v1")
  Container(workerProc, "Background Worker", "Go", "Executa ExternalExpenseConsumer")
  ContainerDb(budgetsDb, "Budgets Store", "PostgreSQL", "expenses e pending_events")
}

Rel(workerProc, outboxStore, "[async] consome external.expense.v1", "dispatcher poll", $tags="async")
Rel(workerProc, budgetsDb, "[sync] aplica create/update/delete externo ou grava pending_event", "SQL", $tags="sync")
Rel(workerProc, outboxStore, "[async] se aplicar com sucesso, publica budgets.expense.committed.v1", "SQL insert", $tags="async")

SHOW_LEGEND()
@enduml
