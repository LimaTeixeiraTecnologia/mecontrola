@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Budgets - BUD-05 Evaluate alert

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "budgets.expense.committed.v1")
  Container(workerProc, "Background Worker", "Go", "Entrega evento ao ExpenseCommittedConsumer")
  ContainerDb(budgetsDb, "Budgets Store", "PostgreSQL", "expenses, budgets, threshold_states e alerts")
}

Rel(workerProc, outboxStore, "[async] consome budgets.expense.committed.v1", "dispatcher poll", $tags="async")
Rel(workerProc, budgetsDb, "[sync] soma gastos, avalia threshold e grava alerts", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
