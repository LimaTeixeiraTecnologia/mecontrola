@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Budgets - BUD-04 Delete expense

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

Person(apiClient, "API Client", "Cliente autenticado")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa DELETE /api/v1/budgets/expenses/{id}")
  ContainerDb(budgetsDb, "Budgets Store", "PostgreSQL", "expenses com soft delete")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "budgets.expense.committed.v1 mutation delete")
}

Rel(apiClient, apiServer, "[sync] DELETE /api/v1/budgets/expenses/{id}", "HTTPS", $tags="sync")
Rel(apiServer, budgetsDb, "[sync] faz soft delete e grava tombstone logico", "SQL", $tags="sync")
Rel(apiServer, outboxStore, "[async] publica budgets.expense.committed.v1 mutation=delete", "SQL insert", $tags="async")

SHOW_LEGEND()
@enduml
