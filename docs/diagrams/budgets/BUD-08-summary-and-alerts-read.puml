@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Budgets - BUD-08 Summary and alerts read

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

Person(apiClient, "API Client", "Cliente autenticado")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa summary e alerts")
  ContainerDb(budgetsDb, "Budgets Store", "PostgreSQL", "budgets, expenses e alerts")
}

Rel(apiClient, apiServer, "[sync] GET /api/v1/budgets/{competence}/summary e GET /api/v1/budgets/alerts", "HTTPS/JSON", $tags="sync")
Rel(apiServer, budgetsDb, "[sync] le agregados e alert rows", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
