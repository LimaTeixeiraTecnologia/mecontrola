@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Categories - CAT-05 Internal reader used by Budgets

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

System_Boundary(mecontrola, "MeControla") {
  Container(budgetsRuntime, "Budgets Runtime", "Go", "Consome CategoriesReaderAdapter no bootstrap e nos use cases")
  Container(categoriesRuntime, "Categories Runtime", "Go", "ResolveBySlug, ValidateSubcategory e VersionReader")
  ContainerDb(categoriesDb, "Categories Store", "PostgreSQL", "categories, dictionary e version")
}

Rel(budgetsRuntime, categoriesRuntime, "[sync] valida subcategoria e resolve root_slug", "in-process adapter", $tags="sync")
Rel(categoriesRuntime, categoriesDb, "[sync] le catalogo editorial e version", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
