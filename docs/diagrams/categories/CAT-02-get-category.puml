@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Categories - CAT-02 Get category

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

Person(apiClient, "API Client", "Cliente autenticado")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa GET /api/v1/categories/{id}")
  ContainerDb(categoriesDb, "Categories Store", "PostgreSQL", "categories e version")
}

Rel(apiClient, apiServer, "[sync] GET /api/v1/categories/{id}", "HTTPS/JSON", $tags="sync")
Rel(apiServer, categoriesDb, "[sync] le detalhe da categoria e version para ETag", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
