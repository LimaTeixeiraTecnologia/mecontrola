@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Identity - IDN-03 WhatsApp inbound routing

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Ext(meta, "Meta WhatsApp Cloud API", "Entrega webhook inbound")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa /api/v1/whatsapp/inbound e dispatcher")
  Container(onboardingRuntime, "Onboarding Runtime", "Go", "Processa ATIVAR <token> e fallback")
  Container(agentRuntime, "Agent Runtime", "Go", "Recebe mensagens de usuarios autenticados")
  ContainerDb(identityDb, "Identity Store", "PostgreSQL", "users, entitlements, whatsapp dedup e limiter state")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "auth.failed e auth.principal_established")
}

Rel(meta, apiServer, "[sync] POST /api/v1/whatsapp/inbound", "HTTPS webhook", $tags="sync")
Rel(apiServer, identityDb, "[sync] dedup wamid, establish principal e consulta limiter", "SQL", $tags="sync")
Rel(apiServer, onboardingRuntime, "[sync] roteia ATIVAR <token> ou unknown user para onboarding", "in-process", $tags="sync")
Rel(apiServer, agentRuntime, "[sync] roteia usuario autenticado para o agent", "in-process", $tags="sync")
Rel(apiServer, outboxStore, "[async] publica auth.failed quando bloqueado por rate limit ou falha de autenticacao", "SQL insert", $tags="async")

SHOW_LEGEND()
@enduml
