@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Identity - IDN-06 Auth events consumer

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "auth.principal_established, auth.failed, auth.unknown_user e user.deleted")
  Container(workerProc, "Background Worker", "Go", "Entrega envelope ao AuthEventsConsumer")
  ContainerDb(identityDb, "Identity Store", "PostgreSQL", "auth_events")
}

Rel(workerProc, outboxStore, "[async] consome auth.* e user.deleted", "dispatcher poll", $tags="async")
Rel(workerProc, identityDb, "[sync] grava ou anonimiza auth_events", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
