@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Identity - IDN-01 Upsert user by WhatsApp

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

Person(apiClient, "API Client", "Operador ou cliente interno")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa POST /api/v1/identity/users/")
  ContainerDb(identityDb, "Identity Store", "PostgreSQL", "users")
}

Rel(apiClient, apiServer, "[sync] POST /api/v1/identity/users/", "HTTPS/JSON", $tags="sync")
Rel(apiServer, identityDb, "[sync] cria ou atualiza user por WhatsApp/email", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
