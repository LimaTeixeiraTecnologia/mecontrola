@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Identity - IDN-04 Billing subscription projection

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "billing.subscription.*")
  Container(workerProc, "Background Worker", "Go", "Entrega envelope ao SubscriptionEventProjector")
  ContainerDb(identityDb, "Identity Store", "PostgreSQL", "subscription projection e entitlements")
}

Rel(workerProc, outboxStore, "[async] consome billing.subscription.*", "dispatcher poll", $tags="async")
Rel(workerProc, identityDb, "[sync] persiste projection de subscription e entitlement", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
