@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Identity - IDN-05 Onboarding subscription bound projection

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "onboarding.subscription_bound")
  Container(workerProc, "Background Worker", "Go", "Entrega envelope ao SubscriptionBoundProjector")
  ContainerDb(identityDb, "Identity Store", "PostgreSQL", "projection e entitlements")
}

Rel(workerProc, outboxStore, "[async] consome onboarding.subscription_bound", "dispatcher poll", $tags="async")
Rel(workerProc, identityDb, "[sync] atualiza projection com bind usuario-assinatura", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
