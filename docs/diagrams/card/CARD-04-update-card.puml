@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Card - CARD-04 Update card

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

Person(apiClient, "API Client", "Cliente autenticado")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa PUT /api/v1/cards/{id}/ com middleware de idempotencia")
  ContainerDb(cardDb, "Card Store", "PostgreSQL", "cards e idempotency keys")
}

Rel(apiClient, apiServer, "[sync] PUT /api/v1/cards/{id}/", "HTTPS/JSON", $tags="sync")
Rel(apiServer, cardDb, "[sync] atualiza cartao e chave de idempotencia", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
