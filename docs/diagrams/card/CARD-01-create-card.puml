@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Card - CARD-01 Create card

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

Person(apiClient, "API Client", "Cliente autenticado")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa POST /api/v1/cards/ com middleware de idempotencia")
  ContainerDb(cardDb, "Card Store", "PostgreSQL", "cards e idempotency keys")
}

Rel(apiClient, apiServer, "[sync] POST /api/v1/cards/", "HTTPS/JSON", $tags="sync")
Rel(apiServer, cardDb, "[sync] grava cartao e chave de idempotencia", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
