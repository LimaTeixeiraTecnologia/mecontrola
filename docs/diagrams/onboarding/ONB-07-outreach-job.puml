@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Onboarding - ONB-07 Outreach job

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

System_Ext(meta, "Meta WhatsApp Cloud API", "Envio outbound")

System_Boundary(mecontrola, "MeControla") {
  Container(workerProc, "Background Worker", "Go", "Executa onboarding.outreach_job")
  ContainerDb(onboardingDb, "Onboarding Store", "PostgreSQL", "magic_tokens e support_signals")
}

Rel(workerProc, onboardingDb, "[sync] seleciona candidatos de outreach", "SQL", $tags="sync")
Rel(workerProc, meta, "[sync] envia mensagem outbound", "HTTPS API", $tags="sync")

SHOW_LEGEND()
@enduml
