@startuml Onboarding - Fluxo: Ativação Telegram
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Dynamic.puml

title Onboarding — Fluxo 4: Ativação via Telegram\n(exige token já CONSUMED via WhatsApp)

Person(user, "Usuário Telegram")
Container(http_api, "HTTP API / Telegram Webhook", "Go/Chi", "")
ContainerDb(postgres, "PostgreSQL", "", "")
System_Ext(identity, "Identity Module")

Rel(user, http_api, "1. /ativar <token> via Telegram")
Rel(http_api, postgres, "2. ActivateTelegramByToken:\n   busca token pelo hash\n   valida status = CONSUMED\n   (WhatsApp deve ter consumido antes)")
Rel(http_api, identity, "3. LinkChannelToUser\n   { userID, channel=telegram,\n     externalID=telegram_user_id }")
Rel(http_api, user, "4a. Token CONSUMED e link feito:\n    'Telegram vinculado com sucesso!'")
Rel(http_api, user, "4b. Token não CONSUMED:\n    'Ative primeiro via WhatsApp'")
Rel(http_api, user, "4c. Token não encontrado:\n    'Token inválido'")

@enduml
