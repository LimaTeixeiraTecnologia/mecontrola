@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Onboarding - ONB-06 Paid without token

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "billing.subscription.activated_without_token")
  Container(workerProc, "Background Worker", "Go", "Executa PaidWithoutTokenConsumer")
  ContainerDb(onboardingDb, "Onboarding Store", "PostgreSQL", "support_signals")
}

Rel(workerProc, outboxStore, "[async] consome billing.subscription.activated_without_token", "dispatcher poll", $tags="async")
Rel(workerProc, onboardingDb, "[sync] grava sinal de suporte/follow-up", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
