@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Onboarding - ONB-05 Mark token paid

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Boundary(mecontrola, "MeControla") {
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "billing.subscription.activated")
  Container(workerProc, "Background Worker", "Go", "Executa SubscriptionPaidConsumer")
  ContainerDb(onboardingDb, "Onboarding Store", "PostgreSQL", "magic_tokens")
}

Rel(workerProc, outboxStore, "[async] consome billing.subscription.activated", "dispatcher poll", $tags="async")
Rel(workerProc, onboardingDb, "[sync] marca token como paid e salva metadados da venda", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
