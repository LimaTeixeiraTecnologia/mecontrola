@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Onboarding - ONB-04 Fallback activation

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

System_Ext(meta, "Meta WhatsApp Cloud API", "Transporte do WhatsApp")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Recebe inbound e aciona fallback")
  ContainerDb(onboardingDb, "Onboarding Store", "PostgreSQL", "magic_tokens e support_signals")
}

Rel(meta, apiServer, "[sync] POST /api/v1/whatsapp/inbound sem comando de ativacao resolvido", "HTTPS webhook", $tags="sync")
Rel(apiServer, onboardingDb, "[sync] busca token pago elegivel ou contexto de suporte", "SQL", $tags="sync")
Rel(apiServer, meta, "[sync] envia resposta welcome_activated ou please_use_ativar_command", "HTTPS API", $tags="sync")

SHOW_LEGEND()
@enduml
