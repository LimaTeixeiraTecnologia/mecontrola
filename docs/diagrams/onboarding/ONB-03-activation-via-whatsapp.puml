@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Onboarding - ONB-03 Activation via WhatsApp

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")
AddRelTag("async", $lineColor="#C65D00", $textColor="#C65D00", $lineStyle=DashedLine(), $legendText="async via outbox")

System_Ext(meta, "Meta WhatsApp Cloud API", "Transporte do WhatsApp")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Recebe inbound e aciona WhatsAppMessageProcessor")
  Container(identityRuntime, "Identity Runtime", "Go", "UpsertUserByWhatsApp via gateway")
  ContainerDb(onboardingDb, "Onboarding Store", "PostgreSQL", "magic_tokens e subscription bindings")
  ContainerDb(outboxStore, "Outbox Events Store", "PostgreSQL", "onboarding.subscription_bound")
}

Rel(meta, apiServer, "[sync] POST /api/v1/whatsapp/inbound com ATIVAR <token>", "HTTPS webhook", $tags="sync")
Rel(apiServer, onboardingDb, "[sync] valida token, consome token e persiste subscription binding", "SQL", $tags="sync")
Rel(apiServer, identityRuntime, "[sync] upserta usuario por WhatsApp/email", "in-process gateway", $tags="sync")
Rel(apiServer, outboxStore, "[async] publica onboarding.subscription_bound", "SQL insert", $tags="async")
Rel(apiServer, meta, "[sync] envia mensagem de confirmacao/erro ao usuario", "HTTPS API", $tags="sync")

SHOW_LEGEND()
@enduml
