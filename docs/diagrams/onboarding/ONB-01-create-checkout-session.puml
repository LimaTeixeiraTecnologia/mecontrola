@startuml
!define RELATIVE_INCLUDE 1
!include ../system/_plantuml/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Container diagram for Onboarding - ONB-01 Create checkout session

AddRelTag("sync", $lineColor="#2F6BFF", $textColor="#2F6BFF", $legendText="sync call")

Person(apiClient, "API Client", "Cliente do fluxo de checkout")

System_Boundary(mecontrola, "MeControla") {
  Container(apiServer, "HTTP API Server", "Go, Chi", "Executa POST /api/v1/onboarding/checkout")
  ContainerDb(onboardingDb, "Onboarding Store", "PostgreSQL", "magic_tokens")
}

Rel(apiClient, apiServer, "[sync] POST /api/v1/onboarding/checkout", "HTTPS/JSON", $tags="sync")
Rel(apiServer, onboardingDb, "[sync] cria magic_token e metadados do checkout", "SQL", $tags="sync")

SHOW_LEGEND()
@enduml
